-- Função de notificação elegante
local function notify(mensagem, duracao)
    duracao = duracao or 2
    
    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 200, 0, 40)
    notifFrame.Position = UDim2.new(0.5, -100, 0.1, 0)
    notifFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    notifFrame.BackgroundTransparency = 0.2
    notifFrame.BorderSizePixel = 0
    notifFrame.ZIndex = 10
    notifFrame.Parent = gui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = notifFrame
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = Color3.fromRGB(255, 100, 100)
    stroke.Parent = notifFrame
    
    local texto = Instance.new("TextLabel")
    texto.Size = UDim2.new(1, -10, 1, 0)
    texto.Position = UDim2.new(0, 5, 0, 0)
    texto.BackgroundTransparency = 1
    texto.Text = mensagem
    texto.TextColor3 = Color3.fromRGB(255, 255, 255)
    texto.TextSize = 14
    texto.Font = Enum.Font.GothamSemibold
    texto.TextXAlignment = Enum.TextXAlignment.Center
    texto.ZIndex = 11
    texto.Parent = notifFrame
    
    -- Animação de entrada
    notifFrame.Position = UDim2.new(0.5, -100, -0.2, 0)
    local entrada = TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -100, 0.05, 0)
    })
    entrada:Play()
    
    -- Remover após duração
    task.wait(duracao)
    local saida = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, -100, -0.2, 0)
    })
    saida:Play()
    saida.Completed:Wait()
    notifFrame:Destroy()
end

