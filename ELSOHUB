-- Sistema de Drag (PC e Mobile)
local dragging = false
local dragInput, dragStart, startPos

local function atualizarDrag(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

titulo.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titulo.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        atualizarDrag(input)
    end
end)

-- Sistema de Drag para o ícone minimizado
local iconeDragging = false
local iconeDragInput, iconeDragStart, iconeStartPos

iconeMinimizado.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 
    or input.UserInputType == Enum.UserInputType.Touch then
        iconeDragging = true
        iconeDragStart = input.Position
        iconeStartPos = iconeMinimizado.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                iconeDragging = false
            end
        end)
    end
end)

iconeMinimizado.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement 
    or input.UserInputType == Enum.UserInputType.Touch then
        iconeDragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == iconeDragInput and iconeDragging then
        local delta = input.Position - iconeDragStart
        iconeMinimizado.Position = UDim2.new(
            iconeStartPos.X.Scale,
            iconeStartPos.X.Offset + delta.X,
            iconeStartPos.Y.Scale,
            iconeStartPos.Y.Offset + delta.Y
        )
    end
end)

-- Sistema de Minimizar/Maximizar (agora como ícone quadrado arredondado)
local minimizado = false
local tamanhoOriginal = frame.Size
local posicaoOriginal = frame.Position

-- Função para atualizar o estado minimizado
local function setMinimizado(estado)
    minimizado = estado
    
    if minimizado then
        -- Salvar posição atual do frame
        posicaoOriginal = frame.Position
        
        -- Esconder frame principal com animação
        local tweenEsconder = TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 1
        })
        tweenEsconder:Play()
        tweenEsconder.Completed:Wait()
        frame.Visible = false
        
        -- Mostrar ícone minimizado com animação
        iconeMinimizado.Visible = true
        iconeMinimizado.Position = UDim2.new(posicaoOriginal.X.Scale, posicaoOriginal.X.Offset, posicaoOriginal.Y.Scale, posicaoOriginal.Y.Offset)
        
        local tweenIcone = TweenService:Create(iconeMinimizado, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 50, 0, 50)
        })
        tweenIcone:Play()
        
        notify("🔥 Hub minimizado", 1.5)
    else
        -- Esconder ícone com animação
        local tweenEsconderIcone = TweenService:Create(iconeMinimizado, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, 0, 0, 0)
        })
        tweenEsconderIcone:Play()
        tweenEsconderIcone.Completed:Wait()
        iconeMinimizado.Visible = false
        
        -- Mostrar frame principal
        frame.Visible = true
        frame.BackgroundTransparency = 0.05
        frame.Size = UDim2.new(0, 0, 0, 0)
        frame.Position = iconeMinimizado.Position
        
        local tweenMostrar = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Size = tamanhoOriginal,
            Position = posicaoOriginal
        })
        tweenMostrar:Play()
        
        notify("🔥 Hub expandido", 1.5)
    end
end

minimizarBtn.MouseButton1Click:Connect(function()
